{
    "name": "keycloak-mcp",
    "version": "1.0.0",
    "description": "Model Context Protocol (MCP) server for Keycloak Admin API — manage realms, users, groups, roles, clients, sessions and events via any MCP-compatible AI assistant.",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "keycloak-mcp": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "node --watch dist/index.js",
        "prepare": "tsc"
    },
    "engines": {
        "node": ">=20"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "keycloak",
        "iam",
        "identity",
        "ai"
    ],
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.6.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "typescript": "^5.7.0"
    }
}